# Required for authenticated API access
API_KEYS=change-me

# Optional application metadata
APP_NAME=Job Intelligence API
APP_VERSION=0.1.0
APP_DESCRIPTION=Beginner-friendly API for public job listing ingestion

# Optional runtime settings
PORT=8000
SQLITE_DB_PATH=data/jobs.db
ARBEITNOW_SOURCE_URL=https://www.arbeitnow.com/api/job-board-api
REMOTIVE_SOURCE_URL=https://remotive.com/api/remote-jobs
THEMUSE_SOURCE_URL=https://www.themuse.com/api/public/jobs?page=1
HTTP_TIMEOUT_SECONDS=15
CACHE_TTL_SECONDS=300
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50

# Logging: CRITICAL, ERROR, WARNING, INFO, DEBUG
LOG_LEVEL=INFO
